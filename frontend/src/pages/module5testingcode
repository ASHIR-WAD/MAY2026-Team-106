            </p>
            <Input
              label="Contained Input Element"
              placeholder="Captured within frame view bounds..."
            />
            <div className="flex gap-2 justify-end pt-2">
              <Button
                variant="secondary"
                onClick={() => setIsModalOpen(false)}
              >
                Cancel
              </Button>
              <Button variant="primary" onClick={() => setIsModalOpen(false)}>
                Confirm Action
              </Button>
            </div>
          </div>
        </Modal>
      </section>
    </div>
